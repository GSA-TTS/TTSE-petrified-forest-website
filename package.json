{
	"name": "ttse-petrified-forest-website",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=10.0.0"
	},
	"scripts": {
		"federalist": "FEDERALIST_BUILD=true npm run build && node scripts/build-404.js",
		"dev": "vite dev",
		"build": "vite build && node scripts/build-404.js",
		"preview": "vite preview",
		"start": "node build/index.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/kit": "^2.14.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.4",
		"@types/node": "^22.10.2",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.2",
		"svelte": "^5.2.9",
		"svelte-check": "^4.1.1",
		"tslib": "^2.8.1",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.18.1",
		"vite": "^6.0.3"
	},
	"dependencies": {
		"@gsa-tts/svelte-ui-uswds": "latest",
		"@uswds/uswds": "^3.13.0"
	}
}
